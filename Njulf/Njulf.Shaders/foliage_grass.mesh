#version 460
#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_mesh_shader : require

#include "common.glsl"

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 32) out;

struct FoliageGrassPayload
{
    uint ClusterIndex;
    uint Visible;
};

taskPayloadSharedEXT FoliageGrassPayload foliagePayload;

layout(location = 0) out vec2 meshTexCoord[];
layout(location = 1) flat out uint meshMaterialIndex[];
layout(location = 2) out vec3 meshWorldPosition[];
layout(location = 3) out vec3 meshNormal[];
layout(location = 4) flat out uint meshClusterIndex[];
layout(location = 5) flat out uint meshLodBand[];
layout(location = 6) flat out uint meshGeometryMode[];
layout(location = 7) flat out uint meshDebugMeshletIndex[];

layout(push_constant) uniform FoliageDrawPushConstantBlock
{
    GPUFoliageDrawPushConstants Push;
} pc;

uint HashUint(uint value)
{
    value ^= value >> 16u;
    value *= 0x7feb352du;
    value ^= value >> 15u;
    value *= 0x846ca68bu;
    value ^= value >> 16u;
    return value;
}

float Hash01(uint value)
{
    return float(HashUint(value) & 0x00ffffffu) / float(0x01000000u);
}

uint SelectLod(vec3 cameraPosition, GPUFoliageCluster cluster, GPUFoliagePrototype prototype)
{
    float distanceToCluster = max(0.0, length(cluster.WorldCenterRadius.xyz - cameraPosition) - cluster.WorldCenterRadius.w);
    if (distanceToCluster <= prototype.LodDistances.x)
        return 0u;
    if (distanceToCluster <= prototype.LodDistances.y)
        return 1u;
    return 2u;
}

void EmitBladeVertex(
    uint vertexIndex,
    vec3 position,
    vec2 uv,
    uint materialIndex,
    uint clusterIndex,
    uint lodBand)
{
    gl_MeshVerticesEXT[vertexIndex].gl_Position = MulRowMajor(vec4(position, 1.0), pc.Push.ViewProjectionMatrix);
    meshTexCoord[vertexIndex] = uv;
    meshMaterialIndex[vertexIndex] = materialIndex;
    meshWorldPosition[vertexIndex] = position;
    meshNormal[vertexIndex] = vec3(0.0, 1.0, 0.0);
    meshClusterIndex[vertexIndex] = clusterIndex;
    meshLodBand[vertexIndex] = lodBand;
    meshGeometryMode[vertexIndex] = 0u;
    meshDebugMeshletIndex[vertexIndex] = clusterIndex;
}

void EmitCardVertex(
    uint vertexIndex,
    vec3 position,
    vec3 normal,
    vec2 uv,
    uint materialIndex,
    uint clusterIndex,
    uint lodBand)
{
    gl_MeshVerticesEXT[vertexIndex].gl_Position = MulRowMajor(vec4(position, 1.0), pc.Push.ViewProjectionMatrix);
    meshTexCoord[vertexIndex] = uv;
    meshMaterialIndex[vertexIndex] = materialIndex;
    meshWorldPosition[vertexIndex] = position;
    meshNormal[vertexIndex] = normal;
    meshClusterIndex[vertexIndex] = clusterIndex;
    meshLodBand[vertexIndex] = lodBand;
    meshGeometryMode[vertexIndex] = 2u;
    meshDebugMeshletIndex[vertexIndex] = clusterIndex;
}

void main()
{
    if (foliagePayload.Visible == 0u)
    {
        if (gl_LocalInvocationIndex == 0u)
            SetMeshOutputsEXT(0u, 0u);
        return;
    }

    GPUFoliageCluster cluster = ReadFoliageCluster(foliagePayload.ClusterIndex);
    GPUFoliagePatch foliagePatch = ReadFoliagePatch(cluster.PatchIndex);
    GPUFoliagePrototype prototype = ReadFoliagePrototype(foliagePatch.PrototypeIndex);

    if (prototype.GeometryMode != 0u && prototype.GeometryMode != 2u)
    {
        if (gl_LocalInvocationIndex == 0u)
            SetMeshOutputsEXT(0u, 0u);
        return;
    }

    uint requestedBlades = min(cluster.InstanceCount, 16u);
    uint lodBand = SelectLod(pc.Push.CameraPositionTime.xyz, cluster, prototype);
    uint bladeCount = lodBand == 0u
        ? requestedBlades
        : (lodBand == 1u ? max(1u, requestedBlades / 2u) : max(1u, requestedBlades / 4u));
    uint vertexCount = bladeCount * 4u;
    uint primitiveCount = bladeCount * 2u;

    if (gl_LocalInvocationIndex == 0u)
        SetMeshOutputsEXT(vertexCount, primitiveCount);

    barrier();

    vec3 boundsMin = cluster.BoundsMinDensity.xyz;
    vec3 boundsMax = cluster.BoundsMaxLod.xyz;
    vec3 extent = max(boundsMax - boundsMin, vec3(0.001));
    float baseHeight = max(0.05, prototype.BladeHeight);
    float baseWidth = max(0.01, prototype.BladeWidth);
    float time = pc.Push.CameraPositionTime.w;

    if (prototype.GeometryMode == 2u)
    {
        vec3 wallSide = vec3(1.0, 0.0, 0.0);
        vec3 wallUp = vec3(0.0, 1.0, 0.0);
        vec3 wallNormal = vec3(0.0, 0.0, 1.0);
        for (uint card = gl_LocalInvocationIndex; card < bladeCount; card += gl_WorkGroupSize.x)
        {
            uint seed = cluster.RandomSeed ^ (card * 747796405u) ^ foliagePatch.Seed;
            float rx = Hash01(seed + 1u);
            float ry = Hash01(seed + 2u);
            float rz = Hash01(seed + 3u);
            float rs = Hash01(seed + 4u);
            float rw = Hash01(seed + 5u);
            float angle = Hash01(seed + 6u) * 6.28318530718;
            vec3 center = vec3(
                boundsMin.x + rx * extent.x,
                boundsMin.y + ry * extent.y,
                boundsMax.z - 0.02 - rz * 0.03);
            vec3 side = normalize(wallSide * cos(angle) + wallUp * sin(angle));
            vec3 up = normalize(-wallSide * sin(angle) + wallUp * cos(angle));

            float height = baseHeight * mix(0.75, 1.25, rs);
            float width = baseWidth * mix(0.75, 1.25, rw);
            float wind = sin(time * prototype.WindParams.y + float(seed & 1023u) * 0.013) * prototype.WindParams.x;
            vec3 windOffset = wallNormal * wind * height * 0.08;
            vec3 halfSide = side * (width * 0.5);
            vec3 halfUp = up * (height * 0.5);
            uint vertexBase = card * 4u;
            uint materialIndex = prototype.MaterialIndex;

            EmitCardVertex(vertexBase + 0u, center - halfSide - halfUp, wallNormal, vec2(0.0, 0.0), materialIndex, foliagePayload.ClusterIndex, lodBand);
            EmitCardVertex(vertexBase + 1u, center + halfSide - halfUp, wallNormal, vec2(1.0, 0.0), materialIndex, foliagePayload.ClusterIndex, lodBand);
            EmitCardVertex(vertexBase + 2u, center - halfSide + halfUp + windOffset, wallNormal, vec2(0.0, 1.0), materialIndex, foliagePayload.ClusterIndex, lodBand);
            EmitCardVertex(vertexBase + 3u, center + halfSide + halfUp + windOffset, wallNormal, vec2(1.0, 1.0), materialIndex, foliagePayload.ClusterIndex, lodBand);
        }

        for (uint primitive = gl_LocalInvocationIndex; primitive < primitiveCount; primitive += gl_WorkGroupSize.x)
        {
            uint card = primitive / 2u;
            uint vertexBase = card * 4u;
            if ((primitive & 1u) == 0u)
                gl_PrimitiveTriangleIndicesEXT[primitive] = uvec3(vertexBase + 0u, vertexBase + 1u, vertexBase + 2u);
            else
                gl_PrimitiveTriangleIndicesEXT[primitive] = uvec3(vertexBase + 2u, vertexBase + 1u, vertexBase + 3u);
        }

        return;
    }

    for (uint blade = gl_LocalInvocationIndex; blade < bladeCount; blade += gl_WorkGroupSize.x)
    {
        uint seed = cluster.RandomSeed ^ (blade * 747796405u) ^ foliagePatch.Seed;
        float rx = Hash01(seed + 1u);
        float rz = Hash01(seed + 2u);
        float rs = Hash01(seed + 3u);
        float ry = Hash01(seed + 4u);
        float angle = Hash01(seed + 5u) * 6.28318530718;
        float wind = sin(time * prototype.WindParams.y + float(seed & 1023u) * 0.013) * prototype.WindParams.x;

        vec3 root = vec3(
            boundsMin.x + rx * extent.x,
            boundsMin.y,
            boundsMin.z + rz * extent.z);
        float height = baseHeight * mix(0.75, 1.25, rs);
        float width = baseWidth * mix(0.70, 1.35, ry);
        vec3 side = normalize(vec3(cos(angle), 0.0, sin(angle))) * width;
        vec3 bend = vec3(side.z, 0.0, -side.x) * wind * height;
        vec3 top = root + vec3(0.0, height, 0.0) + bend;
        uint vertexBase = blade * 4u;
        uint materialIndex = prototype.MaterialIndex;

        EmitBladeVertex(vertexBase + 0u, root - side, vec2(0.0, 0.0), materialIndex, foliagePayload.ClusterIndex, lodBand);
        EmitBladeVertex(vertexBase + 1u, root + side, vec2(1.0, 0.0), materialIndex, foliagePayload.ClusterIndex, lodBand);
        EmitBladeVertex(vertexBase + 2u, top - side * 0.18, vec2(0.15, 1.0), materialIndex, foliagePayload.ClusterIndex, lodBand);
        EmitBladeVertex(vertexBase + 3u, top + side * 0.18, vec2(0.85, 1.0), materialIndex, foliagePayload.ClusterIndex, lodBand);
    }

    for (uint primitive = gl_LocalInvocationIndex; primitive < primitiveCount; primitive += gl_WorkGroupSize.x)
    {
        uint blade = primitive / 2u;
        uint vertexBase = blade * 4u;
        if ((primitive & 1u) == 0u)
            gl_PrimitiveTriangleIndicesEXT[primitive] = uvec3(vertexBase + 0u, vertexBase + 1u, vertexBase + 2u);
        else
            gl_PrimitiveTriangleIndicesEXT[primitive] = uvec3(vertexBase + 2u, vertexBase + 1u, vertexBase + 3u);
    }
}
