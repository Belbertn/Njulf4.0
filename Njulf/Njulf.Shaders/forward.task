#version 460
#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_mesh_shader : require

#include "common.glsl"

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

struct ForwardTaskPayload
{
    uint MeshletDispatchId;
};

taskPayloadSharedEXT ForwardTaskPayload forwardPayload;

void main()
{
    forwardPayload.MeshletDispatchId = gl_WorkGroupID.x;
    EmitMeshTasksEXT(1, 1, 1);
}
