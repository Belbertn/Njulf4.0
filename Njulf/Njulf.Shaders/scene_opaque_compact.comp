#version 460
#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_nonuniform_qualifier : enable

#include "common.glsl"

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform SceneOpaqueCompactionPushConstantBlock
{
    GPUSceneOpaqueCompactionPushConstants Push;
} pc;

const uint SCENE_OPAQUE_COMPACTION_FLAG_FRUSTUM_TEST = 1u << 0u;
const uint SCENE_OPAQUE_COMPACTION_FLAG_GPU_LOD_SELECTION = 1u << 1u;
const uint SCENE_OPAQUE_COMPACTION_FLAG_DIRECTIONAL_SHADOW_COMPACTION = 1u << 2u;
const float SCENE_MESHLET_LOD1_DISTANCE_RATIO = 12.0;
const float SCENE_MESHLET_LOD2_DISTANCE_RATIO = 32.0;
const uint SCENE_DIRECTIONAL_SHADOW_CASCADE_COUNT = 4u;
const uint SCENE_SUBMISSION_COUNTER_OPAQUE_CANDIDATE = 0u;
const uint SCENE_SUBMISSION_COUNTER_OPAQUE_EMITTED = 1u;
const uint SCENE_SUBMISSION_COUNTER_OPAQUE_FRUSTUM_REJECTED = 2u;
const uint SCENE_SUBMISSION_COUNTER_OPAQUE_OVERFLOW = 3u;
const uint SCENE_SUBMISSION_COUNTER_OPAQUE_APPEND = 6u;
const uint SCENE_SUBMISSION_COUNTER_LOD0_EMITTED = 7u;
const uint SCENE_SUBMISSION_COUNTER_MISSING_LOD_FALLBACK = 10u;
const uint SCENE_SUBMISSION_COUNTER_SOLID_DEPTH_CANDIDATE = 11u;
const uint SCENE_SUBMISSION_COUNTER_SOLID_DEPTH_EMITTED = 12u;
const uint SCENE_SUBMISSION_COUNTER_SOLID_DEPTH_OVERFLOW = 13u;
const uint SCENE_SUBMISSION_COUNTER_MASKED_DEPTH_CANDIDATE = 14u;
const uint SCENE_SUBMISSION_COUNTER_MASKED_DEPTH_EMITTED = 15u;
const uint SCENE_SUBMISSION_COUNTER_MASKED_DEPTH_OVERFLOW = 16u;
const uint SCENE_SUBMISSION_COUNTER_SOLID_DEPTH_APPEND = 17u;
const uint SCENE_SUBMISSION_COUNTER_MASKED_DEPTH_APPEND = 18u;
const uint SCENE_SUBMISSION_COUNTER_DIRECTIONAL_STATIC_SHADOW_BASE = 19u;
const uint SCENE_SUBMISSION_COUNTER_DIRECTIONAL_DYNAMIC_SHADOW_BASE = 39u;
const uint SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_STRIDE = 5u;
const uint SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_CANDIDATE_OFFSET = 0u;
const uint SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_EMITTED_OFFSET = 1u;
const uint SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_REJECTED_OFFSET = 2u;
const uint SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_OVERFLOW_OFFSET = 3u;
const uint SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_APPEND_OFFSET = 4u;
const uint SCENE_INDIRECT_DISPATCH_WORD_STRIDE = 4u;
const uint SCENE_INDIRECT_DISPATCH_OPAQUE_SLOT = 0u;
const uint SCENE_INDIRECT_DISPATCH_SOLID_DEPTH_SLOT = 1u;
const uint SCENE_INDIRECT_DISPATCH_MASKED_DEPTH_SLOT = 2u;
const uint SCENE_INDIRECT_DISPATCH_DIRECTIONAL_STATIC_SHADOW_SLOT_BASE = 3u;
const uint SCENE_INDIRECT_DISPATCH_DIRECTIONAL_DYNAMIC_SHADOW_SLOT_BASE =
    SCENE_INDIRECT_DISPATCH_DIRECTIONAL_STATIC_SHADOW_SLOT_BASE + SCENE_DIRECTIONAL_SHADOW_CASCADE_COUNT;

uint CounterBufferIndex()
{
    return pc.Push.CounterBufferBaseIndex + pc.Push.CurrentFrameIndex;
}

uint OutputBufferIndex()
{
    return pc.Push.OutputBufferBaseIndex + pc.Push.CurrentFrameIndex;
}

uint SolidDepthOutputBufferIndex()
{
    return pc.Push.SolidDepthOutputBufferBaseIndex + pc.Push.CurrentFrameIndex;
}

uint MaskedDepthOutputBufferIndex()
{
    return pc.Push.MaskedDepthOutputBufferBaseIndex + pc.Push.CurrentFrameIndex;
}

uint DirectionalStaticShadowOutputBufferIndex(uint cascadeIndex)
{
    return uint(SCENE_DIRECTIONAL_STATIC_SHADOW_COMPACTED_CASCADE0_BUFFER_BASE_INDEX) +
        cascadeIndex * 2u +
        pc.Push.CurrentFrameIndex;
}

uint DirectionalDynamicShadowOutputBufferIndex(uint cascadeIndex)
{
    return uint(SCENE_DIRECTIONAL_DYNAMIC_SHADOW_COMPACTED_CASCADE0_BUFFER_BASE_INDEX) +
        cascadeIndex * 2u +
        pc.Push.CurrentFrameIndex;
}

uint IndirectDispatchBufferIndex()
{
    return pc.Push.IndirectDispatchBufferBaseIndex + pc.Push.CurrentFrameIndex;
}

uint IndirectDispatchCountWord(uint slot)
{
    return slot * SCENE_INDIRECT_DISPATCH_WORD_STRIDE;
}

uint CandidateBufferBaseIndex(uint candidateIndex, out uint localDrawIndex)
{
    if (candidateIndex < pc.Push.SimpleCandidateCount)
    {
        localDrawIndex = candidateIndex;
        return uint(MESHLET_DRAW_BUFFER_BASE_INDEX);
    }

    uint simpleNormalStart = pc.Push.SimpleCandidateCount;
    uint fullStart = simpleNormalStart + pc.Push.SimpleNormalCandidateCount;
    if (candidateIndex < fullStart)
    {
        localDrawIndex = candidateIndex - simpleNormalStart;
        return uint(SIMPLE_NORMAL_OPAQUE_MESHLET_DRAW_BUFFER_BASE_INDEX);
    }

    localDrawIndex = candidateIndex - fullStart;
    return uint(FULL_OPAQUE_MESHLET_DRAW_BUFFER_BASE_INDEX);
}

GPUMeshInfo ReadMeshInfo(uint meshIndex)
{
    uint baseWord = meshIndex * uint(SIZEOF_GPU_MESH_INFO / 4);
    GPUMeshInfo info;
    info.BoundingSphere = ReadStorageVec4(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 0u);
    info.SkinningDataOffset = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 4u);
    info.SkinningDataCount = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 5u);
    info.Flags = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 6u);
    info.MeshletOffset = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 7u);
    info.MeshletCount = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 8u);
    info.MeshletLod1Offset = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 9u);
    info.MeshletLod1Count = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 10u);
    info.MeshletLod2Offset = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 11u);
    info.MeshletLod2Count = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 12u);
    info.MeshletLodGeneratedCount = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 13u);
    info.Padding0 = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 14u);
    info.Padding1 = ReadStorageWord(uint(SCENE_MESH_METADATA_BUFFER_INDEX), baseWord + 15u);
    return info;
}

void WriteMeshletDrawCommandToBase(uint outputBufferIndex, uint outputIndex, GPUMeshletDrawCommand command)
{
    uint baseWord = outputIndex * uint(SIZEOF_GPU_MESHLET_DRAW_COMMAND / 4);
    WriteStorageWord(outputBufferIndex, baseWord + 0u, command.MeshletIndex);
    WriteStorageWord(outputBufferIndex, baseWord + 1u, command.InstanceId);
    WriteStorageWord(outputBufferIndex, baseWord + 2u, command.MaterialIndex);
    WriteStorageWord(outputBufferIndex, baseWord + 3u, command.Padding);
}

void WriteMeshletDrawCommand(uint outputIndex, GPUMeshletDrawCommand command)
{
    WriteMeshletDrawCommandToBase(OutputBufferIndex(), outputIndex, command);
}

float ReadInstanceMaxScale(uint instanceBufferIndex, uint objectWordOffset)
{
    vec3 basisX = TransformRowMajorVector(vec3(1.0, 0.0, 0.0), instanceBufferIndex, objectWordOffset);
    vec3 basisY = TransformRowMajorVector(vec3(0.0, 1.0, 0.0), instanceBufferIndex, objectWordOffset);
    vec3 basisZ = TransformRowMajorVector(vec3(0.0, 0.0, 1.0), instanceBufferIndex, objectWordOffset);
    return max(length(basisX), max(length(basisY), length(basisZ)));
}

bool IsMeshletVisible(GPUMeshletDrawCommand command, vec4 frustumPlanes[6])
{
    if ((pc.Push.Flags & SCENE_OPAQUE_COMPACTION_FLAG_FRUSTUM_TEST) == 0u)
        return true;

    uint instanceBufferIndex = uint(INSTANCE_BUFFER_BASE_INDEX) + pc.Push.CurrentFrameIndex;
    uint objectWordOffset = command.InstanceId * uint(SIZEOF_GPU_OBJECT_DATA / 4);
    GPUMeshlet meshlet = ReadMeshlet(command.MeshletIndex);
    vec4 worldCenter = TransformRowMajorPoint(meshlet.BoundingSphereCenter, instanceBufferIndex, objectWordOffset);
    float worldRadius = meshlet.BoundingSphereRadius * ReadInstanceMaxScale(instanceBufferIndex, objectWordOffset);

    return SphereIntersectsFrustumPlanes(worldCenter.xyz, worldRadius, frustumPlanes);
}

bool IsMeshletVisibleToMatrix(GPUMeshletDrawCommand command, mat4 viewProjection)
{
    uint instanceBufferIndex = uint(INSTANCE_BUFFER_BASE_INDEX) + pc.Push.CurrentFrameIndex;
    uint objectWordOffset = command.InstanceId * uint(SIZEOF_GPU_OBJECT_DATA / 4);
    GPUMeshlet meshlet = ReadMeshlet(command.MeshletIndex);
    vec4 worldCenter = TransformRowMajorPoint(meshlet.BoundingSphereCenter, instanceBufferIndex, objectWordOffset);
    float worldRadius = meshlet.BoundingSphereRadius * ReadInstanceMaxScale(instanceBufferIndex, objectWordOffset);
    return SphereIntersectsRowMajorFrustum(worldCenter.xyz, worldRadius, viewProjection);
}

uint SelectLodLevel(vec3 cameraPosition, vec3 worldCenter, float worldRadius)
{
    float effectiveRadius = max(worldRadius, 1.0);
    float distanceFromSurface = max(0.0, length(cameraPosition - worldCenter) - effectiveRadius);
    float distanceRatio = distanceFromSurface / effectiveRadius;
    if (distanceRatio >= SCENE_MESHLET_LOD2_DISTANCE_RATIO)
        return 2u;
    if (distanceRatio >= SCENE_MESHLET_LOD1_DISTANCE_RATIO)
        return 1u;
    return 0u;
}

void SelectMeshletRange(GPUMeshInfo meshInfo, uint requestedLod, out uint firstMeshlet, out uint meshletCount, out uint effectiveLod)
{
    if (requestedLod == 0u && meshInfo.MeshletCount > 0u)
    {
        firstMeshlet = meshInfo.MeshletOffset;
        meshletCount = meshInfo.MeshletCount;
        effectiveLod = 0u;
        return;
    }

    if (requestedLod == 1u && meshInfo.MeshletLod1Count > 0u)
    {
        firstMeshlet = meshInfo.MeshletLod1Offset;
        meshletCount = meshInfo.MeshletLod1Count;
        effectiveLod = 1u;
        return;
    }

    if (requestedLod == 2u && meshInfo.MeshletLod2Count > 0u)
    {
        firstMeshlet = meshInfo.MeshletLod2Offset;
        meshletCount = meshInfo.MeshletLod2Count;
        effectiveLod = 2u;
        return;
    }

    if (meshInfo.MeshletCount > 0u)
    {
        firstMeshlet = meshInfo.MeshletOffset;
        meshletCount = meshInfo.MeshletCount;
        effectiveLod = 0u;
        return;
    }

    if (meshInfo.MeshletLod1Count > 0u)
    {
        firstMeshlet = meshInfo.MeshletLod1Offset;
        meshletCount = meshInfo.MeshletLod1Count;
        effectiveLod = 1u;
        return;
    }

    firstMeshlet = meshInfo.MeshletLod2Offset;
    meshletCount = meshInfo.MeshletLod2Count;
    effectiveLod = 2u;
}

bool ApplyGpuLodSelection(inout GPUMeshletDrawCommand command, out uint effectiveLod)
{
    effectiveLod = 0u;
    if ((pc.Push.Flags & SCENE_OPAQUE_COMPACTION_FLAG_GPU_LOD_SELECTION) == 0u)
        return true;

    uint instanceBufferIndex = uint(INSTANCE_BUFFER_BASE_INDEX) + pc.Push.CurrentFrameIndex;
    uint objectWordOffset = command.InstanceId * uint(SIZEOF_GPU_OBJECT_DATA / 4);
    GPUObjectData objectData = ReadInstanceData(pc.Push.CurrentFrameIndex, command.InstanceId);
    GPUMeshInfo meshInfo = ReadMeshInfo(uint(max(objectData.MeshIndex, 0)));

    uint lod0LocalIndex = command.MeshletIndex >= meshInfo.MeshletOffset
        ? command.MeshletIndex - meshInfo.MeshletOffset
        : 0xffffffffu;
    if (lod0LocalIndex >= meshInfo.MeshletCount)
        return true;

    vec4 worldCenter = TransformRowMajorPoint(meshInfo.BoundingSphere.xyz, instanceBufferIndex, objectWordOffset);
    float worldRadius = meshInfo.BoundingSphere.w * ReadInstanceMaxScale(instanceBufferIndex, objectWordOffset);
    uint requestedLod = SelectLodLevel(pc.Push.CameraPosition.xyz, worldCenter.xyz, worldRadius);

    uint firstMeshlet = 0u;
    uint meshletCount = 0u;
    SelectMeshletRange(meshInfo, requestedLod, firstMeshlet, meshletCount, effectiveLod);
    if (meshletCount == 0u)
    {
        atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[SCENE_SUBMISSION_COUNTER_MISSING_LOD_FALLBACK], 1u);
        return false;
    }

    if (effectiveLod != requestedLod)
        atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[SCENE_SUBMISSION_COUNTER_MISSING_LOD_FALLBACK], 1u);

    if (lod0LocalIndex >= meshletCount)
        return false;

    command.MeshletIndex = firstMeshlet + lod0LocalIndex;
    return true;
}

void ProcessOpaqueCandidate(uint candidateIndex, vec4 frustumPlanes[6])
{
    uint candidateCount = pc.Push.SimpleCandidateCount +
        pc.Push.SimpleNormalCandidateCount +
        pc.Push.FullCandidateCount;
    if (candidateIndex >= candidateCount)
        return;

    atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[SCENE_SUBMISSION_COUNTER_OPAQUE_CANDIDATE], 1u);

    uint localDrawIndex = 0u;
    uint candidateBufferBaseIndex = CandidateBufferBaseIndex(candidateIndex, localDrawIndex);
    GPUMeshletDrawCommand command = ReadMeshletDrawCommandFromBase(
        candidateBufferBaseIndex,
        pc.Push.CurrentFrameIndex,
        localDrawIndex);

    uint effectiveLod = 0u;
    if (!ApplyGpuLodSelection(command, effectiveLod))
        return;

    if (!IsMeshletVisible(command, frustumPlanes))
    {
        atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[SCENE_SUBMISSION_COUNTER_OPAQUE_FRUSTUM_REJECTED], 1u);
        return;
    }

    uint outputIndex = atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[SCENE_SUBMISSION_COUNTER_OPAQUE_APPEND], 1u);
    if (outputIndex >= pc.Push.OutputCapacity)
    {
        atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[SCENE_SUBMISSION_COUNTER_OPAQUE_OVERFLOW], 1u);
        return;
    }

    WriteMeshletDrawCommand(outputIndex, command);
    atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[SCENE_SUBMISSION_COUNTER_OPAQUE_EMITTED], 1u);
    atomicAdd(BindlessStorageBuffers[nonuniformEXT(IndirectDispatchBufferIndex())].Words[
        IndirectDispatchCountWord(SCENE_INDIRECT_DISPATCH_OPAQUE_SLOT)], 1u);
    atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[SCENE_SUBMISSION_COUNTER_LOD0_EMITTED + min(effectiveLod, 2u)], 1u);
}

void ProcessDepthCandidate(
    uint candidateIndex,
    uint candidateCount,
    uint inputBufferBaseIndex,
    uint outputBufferIndex,
    uint outputCapacity,
    uint candidateCounterWord,
    uint appendCounterWord,
    uint emittedCounterWord,
    uint overflowCounterWord,
    uint indirectDispatchSlot,
    vec4 frustumPlanes[6])
{
    if (candidateIndex >= candidateCount)
        return;

    atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[candidateCounterWord], 1u);

    GPUMeshletDrawCommand command = ReadMeshletDrawCommandFromBase(
        inputBufferBaseIndex,
        pc.Push.CurrentFrameIndex,
        candidateIndex);

    uint effectiveLod = 0u;
    if (!ApplyGpuLodSelection(command, effectiveLod))
        return;

    if (!IsMeshletVisible(command, frustumPlanes))
        return;

    uint outputIndex = atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[appendCounterWord], 1u);
    if (outputIndex >= outputCapacity)
    {
        atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[overflowCounterWord], 1u);
        return;
    }

    WriteMeshletDrawCommandToBase(outputBufferIndex, outputIndex, command);
    atomicAdd(BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[emittedCounterWord], 1u);
    atomicAdd(BindlessStorageBuffers[nonuniformEXT(IndirectDispatchBufferIndex())].Words[
        IndirectDispatchCountWord(indirectDispatchSlot)], 1u);
}

void ProcessDirectionalShadowCandidate(
    uint candidateIndex,
    uint candidateCount,
    uint inputBufferBaseIndex,
    uint outputCapacity,
    uint counterBaseWord,
    bool dynamicShadow)
{
    if ((pc.Push.Flags & SCENE_OPAQUE_COMPACTION_FLAG_DIRECTIONAL_SHADOW_COMPACTION) == 0u ||
        candidateIndex >= candidateCount)
        return;

    GPUMeshletDrawCommand command = ReadMeshletDrawCommandFromBase(
        inputBufferBaseIndex,
        pc.Push.CurrentFrameIndex,
        candidateIndex);

    uint effectiveLod = 0u;
    if (!ApplyGpuLodSelection(command, effectiveLod))
        return;

    uint cascadeCount = min(pc.Push.DirectionalShadowCascadeCount, SCENE_DIRECTIONAL_SHADOW_CASCADE_COUNT);
    for (uint cascade = 0u; cascade < cascadeCount; cascade++)
    {
        uint cascadeCounterBase = counterBaseWord + cascade * SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_STRIDE;
        atomicAdd(
            BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[
                cascadeCounterBase + SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_CANDIDATE_OFFSET],
            1u);

        if (!IsMeshletVisibleToMatrix(command, ReadShadowMatrix(cascade)))
        {
            atomicAdd(
                BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[
                    cascadeCounterBase + SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_REJECTED_OFFSET],
                1u);
            continue;
        }

        uint outputIndex = atomicAdd(
            BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[
                cascadeCounterBase + SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_APPEND_OFFSET],
            1u);
        if (outputIndex >= outputCapacity)
        {
            atomicAdd(
                BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[
                    cascadeCounterBase + SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_OVERFLOW_OFFSET],
                1u);
            continue;
        }

        uint outputBufferIndex = dynamicShadow
            ? DirectionalDynamicShadowOutputBufferIndex(cascade)
            : DirectionalStaticShadowOutputBufferIndex(cascade);
        WriteMeshletDrawCommandToBase(outputBufferIndex, outputIndex, command);
        atomicAdd(
            BindlessStorageBuffers[nonuniformEXT(CounterBufferIndex())].Words[
                cascadeCounterBase + SCENE_SUBMISSION_COUNTER_DIRECTIONAL_SHADOW_EMITTED_OFFSET],
            1u);
        uint indirectDispatchSlot = dynamicShadow
            ? SCENE_INDIRECT_DISPATCH_DIRECTIONAL_DYNAMIC_SHADOW_SLOT_BASE + cascade
            : SCENE_INDIRECT_DISPATCH_DIRECTIONAL_STATIC_SHADOW_SLOT_BASE + cascade;
        atomicAdd(BindlessStorageBuffers[nonuniformEXT(IndirectDispatchBufferIndex())].Words[
            IndirectDispatchCountWord(indirectDispatchSlot)], 1u);
    }
}

void main()
{
    uint candidateIndex = gl_GlobalInvocationID.x;
    vec4 frustumPlanes[6];
    ReadMeshletTaskFrustumPlanes(pc.Push.CurrentFrameIndex, frustumPlanes);

    ProcessOpaqueCandidate(candidateIndex, frustumPlanes);
    ProcessDepthCandidate(
        candidateIndex,
        pc.Push.SolidDepthCandidateCount,
        uint(SOLID_DEPTH_MESHLET_DRAW_BUFFER_BASE_INDEX),
        SolidDepthOutputBufferIndex(),
        pc.Push.SolidDepthOutputCapacity,
        SCENE_SUBMISSION_COUNTER_SOLID_DEPTH_CANDIDATE,
        SCENE_SUBMISSION_COUNTER_SOLID_DEPTH_APPEND,
        SCENE_SUBMISSION_COUNTER_SOLID_DEPTH_EMITTED,
        SCENE_SUBMISSION_COUNTER_SOLID_DEPTH_OVERFLOW,
        SCENE_INDIRECT_DISPATCH_SOLID_DEPTH_SLOT,
        frustumPlanes);
    ProcessDepthCandidate(
        candidateIndex,
        pc.Push.MaskedDepthCandidateCount,
        uint(MASKED_DEPTH_MESHLET_DRAW_BUFFER_BASE_INDEX),
        MaskedDepthOutputBufferIndex(),
        pc.Push.MaskedDepthOutputCapacity,
        SCENE_SUBMISSION_COUNTER_MASKED_DEPTH_CANDIDATE,
        SCENE_SUBMISSION_COUNTER_MASKED_DEPTH_APPEND,
        SCENE_SUBMISSION_COUNTER_MASKED_DEPTH_EMITTED,
        SCENE_SUBMISSION_COUNTER_MASKED_DEPTH_OVERFLOW,
        SCENE_INDIRECT_DISPATCH_MASKED_DEPTH_SLOT,
        frustumPlanes);
    ProcessDirectionalShadowCandidate(
        candidateIndex,
        pc.Push.DirectionalStaticShadowCandidateCount,
        uint(DIRECTIONAL_STATIC_SHADOW_MESHLET_DRAW_BUFFER_BASE_INDEX),
        pc.Push.DirectionalStaticShadowOutputCapacity,
        SCENE_SUBMISSION_COUNTER_DIRECTIONAL_STATIC_SHADOW_BASE,
        false);
    ProcessDirectionalShadowCandidate(
        candidateIndex,
        pc.Push.DirectionalDynamicShadowCandidateCount,
        uint(DIRECTIONAL_DYNAMIC_SHADOW_MESHLET_DRAW_BUFFER_BASE_INDEX),
        pc.Push.DirectionalDynamicShadowOutputCapacity,
        SCENE_SUBMISSION_COUNTER_DIRECTIONAL_DYNAMIC_SHADOW_BASE,
        true);
}
