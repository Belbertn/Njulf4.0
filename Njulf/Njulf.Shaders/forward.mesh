#version 460
#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_mesh_shader : require

#include "common.glsl"

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 3, max_primitives = 1) out;

struct ForwardTaskPayload
{
    uint MeshletDispatchId;
};

taskPayloadSharedEXT ForwardTaskPayload forwardPayload;

layout(location = 0) out vec3 meshNormal[];
layout(location = 1) out vec2 meshTexCoord[];
layout(location = 2) flat out uint meshMaterialIndex[];

layout(push_constant) uniform ForwardPushConstantBlock
{
    GPUForwardPushConstants Push;
} pc;

void main()
{
    SetMeshOutputsEXT(3, 1);

    gl_MeshVerticesEXT[0].gl_Position = vec4(-0.5, -0.5, 0.5, 1.0);
    gl_MeshVerticesEXT[1].gl_Position = vec4( 0.5, -0.5, 0.5, 1.0);
    gl_MeshVerticesEXT[2].gl_Position = vec4( 0.0,  0.5, 0.5, 1.0);
    gl_PrimitiveTriangleIndicesEXT[0] = uvec3(0, 1, 2);

    meshNormal[0] = vec3(0.0, 0.0, 1.0);
    meshNormal[1] = vec3(0.0, 0.0, 1.0);
    meshNormal[2] = vec3(0.0, 0.0, 1.0);

    meshTexCoord[0] = vec2(0.0, 0.0);
    meshTexCoord[1] = vec2(1.0, 0.0);
    meshTexCoord[2] = vec2(0.5, 1.0);

    meshMaterialIndex[0] = 0;
    meshMaterialIndex[1] = 0;
    meshMaterialIndex[2] = 0;
}
