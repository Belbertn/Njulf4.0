#version 460
#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_mesh_shader : require

#include "common.glsl"

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 126) out;

struct FoliageMotionPayload
{
    uint DrawCommandIndex;
    uint Visible;
};

taskPayloadSharedEXT FoliageMotionPayload foliageMotionPayload;

layout(location = 0) noperspective out vec2 meshCurrentUv[];
layout(location = 1) noperspective out vec2 meshPreviousUv[];
layout(location = 2) out vec2 meshTexCoord[];
layout(location = 3) flat out uint meshMaterialIndex[];

layout(push_constant) uniform MotionVectorPushConstantBlock
{
    GPUMotionVectorPushConstants Push;
} pc;

vec2 ClipToUv(vec4 clip)
{
    vec2 ndc = clip.xy / max(abs(clip.w), 0.000001);
    return ndc * 0.5 + vec2(0.5);
}

vec3 ApplyAuthoredFoliageWindAtTime(
    vec3 worldPosition,
    GPUFoliageInstance instance,
    GPUFoliagePrototype prototype,
    float time)
{
    float strength = prototype.WindParams.x;
    if (strength <= 0.0)
        return worldPosition;

    float frequency = max(0.01, prototype.WindParams.y);
    float flutter = prototype.WindParams.z;
    float phase = dot(worldPosition.xz, vec2(0.137, 0.173)) +
        instance.RotationWind.y * 6.28318530718 +
        time * frequency;
    float sway = sin(phase) * strength;
    float leafFlutter = sin(phase * 3.1 + instance.RotationWind.z * 11.0) * flutter * strength;
    return worldPosition + vec3(sway + leafFlutter, leafFlutter * 0.15, sway * 0.45) * 0.05;
}

vec3 TransformFoliagePointAtTime(vec3 localPosition, GPUFoliageInstance instance, GPUFoliagePrototype prototype, float time)
{
    vec3 worldPosition = instance.PositionScale.xyz + localPosition * max(instance.PositionScale.w, 0.0001);
    return ApplyAuthoredFoliageWindAtTime(worldPosition, instance, prototype, time);
}

void main()
{
    if (foliageMotionPayload.Visible == 0u)
    {
        if (gl_LocalInvocationIndex == 0u)
            SetMeshOutputsEXT(0u, 0u);
        return;
    }

    GPUFoliageMeshletDrawCommand command = ReadFoliageMeshletDrawCommand(
        pc.Push.CurrentFrameIndex,
        foliageMotionPayload.DrawCommandIndex);
    if (command.MeshletIndex == 0xffffffffu)
    {
        if (gl_LocalInvocationIndex == 0u)
            SetMeshOutputsEXT(0u, 0u);
        return;
    }

    GPUMeshlet meshlet = ReadMeshlet(command.MeshletIndex);
    GPUFoliagePrototype prototype = ReadFoliagePrototype(command.PrototypeIndex);
    uint previousFrameIndex = (pc.Push.CurrentFrameIndex + 1u) % uint(FRAMES_IN_FLIGHT);
    GPUFoliageInstance currentInstance = ReadFoliageInstance(pc.Push.CurrentFrameIndex, command.InstanceIndex);
    GPUFoliageInstance previousInstance = ReadFoliageInstance(previousFrameIndex, command.InstanceIndex);

    if (gl_LocalInvocationIndex == 0u)
        SetMeshOutputsEXT(meshlet.LocalVertexCount, meshlet.LocalTriangleCount);

    barrier();

    for (uint vertexSlot = gl_LocalInvocationIndex;
         vertexSlot < meshlet.LocalVertexCount;
         vertexSlot += gl_WorkGroupSize.x)
    {
        uint localVertexIndex = ReadStorageWord(
            uint(MESHLET_VERTEX_INDEX_BUFFER_INDEX),
            meshlet.LocalVertexOffset + vertexSlot);
        GPUVertex vertex = ReadSplitVertex(meshlet.VertexOffset + localVertexIndex);
        vec3 currentWorldPosition = TransformFoliagePointAtTime(vertex.Position, currentInstance, prototype, pc.Push.Time);
        vec3 previousWorldPosition = TransformFoliagePointAtTime(vertex.Position, previousInstance, prototype, pc.Push.PreviousTime);
        vec4 currentClip = MulRowMajor(vec4(currentWorldPosition, 1.0), pc.Push.ViewProjectionMatrix);
        vec4 previousClip = MulRowMajor(vec4(previousWorldPosition, 1.0), pc.Push.PreviousViewProjectionMatrix);

        gl_MeshVerticesEXT[vertexSlot].gl_Position = currentClip;
        meshCurrentUv[vertexSlot] = ClipToUv(currentClip);
        meshPreviousUv[vertexSlot] = pc.Push.PreviousFrameValid != 0u ? ClipToUv(previousClip) : meshCurrentUv[vertexSlot];
        meshTexCoord[vertexSlot] = vertex.TexCoord;
        meshMaterialIndex[vertexSlot] = command.MaterialIndex;
    }

    for (uint triangleSlot = gl_LocalInvocationIndex;
         triangleSlot < meshlet.LocalTriangleCount;
         triangleSlot += gl_WorkGroupSize.x)
    {
        uint triangleOffset = meshlet.LocalTriangleOffset + triangleSlot * 3u;
        uint i0 = ReadStorageWord(uint(MESHLET_TRIANGLE_INDEX_BUFFER_INDEX), triangleOffset + 0u);
        uint i1 = ReadStorageWord(uint(MESHLET_TRIANGLE_INDEX_BUFFER_INDEX), triangleOffset + 1u);
        uint i2 = ReadStorageWord(uint(MESHLET_TRIANGLE_INDEX_BUFFER_INDEX), triangleOffset + 2u);
        gl_PrimitiveTriangleIndicesEXT[triangleSlot] = uvec3(i0, i1, i2);
    }
}
