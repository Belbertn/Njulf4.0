#version 460
#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_mesh_shader : require

#include "common.glsl"

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 126) out;

struct ForwardTaskPayload
{
    uint DrawCommandIndex;
    uint Visible;
};

taskPayloadSharedEXT ForwardTaskPayload forwardPayload;

layout(location = 0) out vec3 meshNormal[];
layout(location = 1) out vec2 meshTexCoord[];
layout(location = 2) flat out uint meshMaterialIndex[];
layout(location = 3) flat out uint meshObjectIndex[];
layout(location = 4) out vec3 meshWorldPosition[];
layout(location = 5) out vec4 meshWorldTangent[];
layout(location = 6) flat out uint meshMeshletIndex[];
layout(location = 7) out vec2 meshTexCoord2[];
layout(location = 8) out vec4 meshVertexColor[];

layout(push_constant) uniform ForwardPushConstantBlock
{
    GPUForwardPushConstants Push;
} pc;

void main()
{
    if (forwardPayload.Visible == 0u)
    {
        if (gl_LocalInvocationIndex == 0u)
            SetMeshOutputsEXT(0u, 0u);
        return;
    }

    GPUMeshletDrawCommand command = ReadMeshletDrawCommandFromBase(
        pc.Push.MeshletDrawBufferBaseIndex,
        pc.Push.CurrentFrameIndex,
        forwardPayload.DrawCommandIndex);
    GPUMeshlet meshlet = ReadMeshlet(command.MeshletIndex);

    if (gl_LocalInvocationIndex == 0u)
        SetMeshOutputsEXT(meshlet.LocalVertexCount, meshlet.LocalTriangleCount);

    barrier();

    GPUObjectData objectData = ReadGpuSceneRenderableData(command.InstanceId);

    for (uint vertexSlot = gl_LocalInvocationIndex;
         vertexSlot < meshlet.LocalVertexCount;
         vertexSlot += gl_WorkGroupSize.x)
    {
        uint localVertexIndex = ReadStorageWord(
            uint(MESHLET_VERTEX_INDEX_BUFFER_INDEX),
            meshlet.LocalVertexOffset + vertexSlot);
        GPUVertex vertex = FetchRenderableVertex(meshlet, localVertexIndex, objectData, pc.Push.CurrentFrameIndex);

        vec4 worldPosition = TransformGpuScenePoint(vertex.Position, command.InstanceId);
        vec3 worldNormal = normalize(TransformGpuSceneVector(vertex.Normal, command.InstanceId));
        vec3 worldTangent = normalize(TransformGpuSceneVector(vertex.Tangent.xyz, command.InstanceId));

        gl_MeshVerticesEXT[vertexSlot].gl_Position = MulRowMajor(worldPosition, pc.Push.ViewProjectionMatrix);
        meshNormal[vertexSlot] = worldNormal;
        meshTexCoord[vertexSlot] = vertex.TexCoord;
        meshMaterialIndex[vertexSlot] = command.MaterialIndex;
        meshObjectIndex[vertexSlot] = command.InstanceId;
        meshWorldPosition[vertexSlot] = worldPosition.xyz;
        meshWorldTangent[vertexSlot] = vec4(worldTangent, vertex.Tangent.w);
        meshMeshletIndex[vertexSlot] = command.MeshletIndex;
        meshTexCoord2[vertexSlot] = vertex.TexCoord2;
        meshVertexColor[vertexSlot] = vertex.Color;
    }

    for (uint triangleSlot = gl_LocalInvocationIndex;
         triangleSlot < meshlet.LocalTriangleCount;
         triangleSlot += gl_WorkGroupSize.x)
    {
        uint triangleOffset = meshlet.LocalTriangleOffset + triangleSlot * 3u;
        uint i0 = ReadStorageWord(uint(MESHLET_TRIANGLE_INDEX_BUFFER_INDEX), triangleOffset + 0u);
        uint i1 = ReadStorageWord(uint(MESHLET_TRIANGLE_INDEX_BUFFER_INDEX), triangleOffset + 1u);
        uint i2 = ReadStorageWord(uint(MESHLET_TRIANGLE_INDEX_BUFFER_INDEX), triangleOffset + 2u);
        gl_PrimitiveTriangleIndicesEXT[triangleSlot] = uvec3(i0, i1, i2);
    }
}
